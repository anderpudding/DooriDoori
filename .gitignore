# macOS
.DS_Store
.AppleDouble
.LSOverride

# Xcode
#
# gitignore contributors: remember to update Global/Xcode.gitignore, Objective-C.gitignore & Swift.gitignore

## User settings
xcuserdata/
*.xcuserstate
*.xcscmblueprint
*.xccheckout
*.moved-aside
*.xcuserdatad/

## Build outputs
DerivedData/
build/
*.ipa
*.dSYM.zip
*.dSYM

## Obj-C / Swift specific
*.hmap

## Playgrounds
timeline.xctimeline
playground.xcworkspace

# Swift Package Manager
.build/
.swiftpm/

# Usually commit Package.resolved for app projects to keep dependency versions stable.
# Package.resolved

# CocoaPods
#
# If this project uses CocoaPods and you want reproducible installs without pod install,
# you may choose to commit Pods/. Otherwise, keep this ignored.
Pods/

# Carthage
Carthage/Build/
Carthage/Checkouts/

# fastlane
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/**/*.png
fastlane/test_output/

# Node / Supabase Edge Functions
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
deno.lock

# Environment variables
.env
.env.*
!.env.example

# Local config / secrets
*.local
*.secret
Secrets.xcconfig
Local.xcconfig
Config.local.xcconfig
GoogleService-Info.local.plist

# Supabase
supabase/.temp/
supabase/.branches/
supabase/.env
supabase/.env.*
supabase/functions/.env
supabase/functions/.env.*

# Large/raw FSQ exports. Keep tiny samples only.
supabase/seed_data/*
!supabase/seed_data/
!supabase/seed_data/fsq_places_sample.json
!supabase/seed_data/fsq_places_sample.csv

# Logs
*.log

# API keys / credentials
*service-role*
*service_role*
*secret*
*apikey*
*api-key*
*credentials*
